{
  "name": "@nor-data/udir-mcp",
  "version": "0.1.2",
  "description": "MCP server exposing Norway's national school (NSR) and kindergarten (NBR) registries from UDIR — search by municipality and fetch full detail with coordinates, pupil counts and ownership.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "drist-udir-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LISTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3121n/nor-data-udir-mcp.git"
  },
  "homepage": "https://github.com/3121n/nor-data-udir-mcp#readme",
  "bugs": {
    "url": "https://github.com/3121n/nor-data-udir-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "node test-e2e.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "norway",
    "udir",
    "school",
    "kindergarten",
    "education",
    "nsr",
    "nbr",
    "skole",
    "barnehage",
    "norge"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "mcpName": "io.github.3121n/udir-mcp"
}