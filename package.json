{
  "name": "@drist/udir-mcp",
  "version": "0.1.0",
  "description": "MCP server som wrapper UDIR sine åpne registre: NSR (Nasjonalt skoleregister) og NBR (Nasjonalt barnehageregister) — søk per kommune og full detalj med koordinater, elevtall og eierform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "drist-udir-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "node test-e2e.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "udir",
    "nsr",
    "nbr",
    "skole",
    "barnehage",
    "norge"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
